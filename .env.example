# ─────────────────────────────────────────────────────────────────────────────
# BG Jewels Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ── MySQL Database ────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=jewellery

# ── Jewelscore API ────────────────────────────────────────────────────────────
JEWELS_API_KEY=your-jewelscore-api-key
JEWELS_BASE_URL=https://bgjewels.jewelscore.com

# ── CLIP Model ────────────────────────────────────────────────────────────────
CLIP_MODEL=ViT-B/32

# NOTE: IMG_BASE and SKU_IMG_BASE are hardcoded in main.py (not sensitive)
