{"openapi":"3.1.0","info":{"title":"BG Jewels Search API","description":"Image search (CLIP image encoder) + Text search (CLIP text encoder) via FAISS","version":"4.0.0"},"paths":{"/rag/save":{"post":{"tags":["RAG Pipeline"],"summary":"Save a description as a RAG transcript","description":"**SAVE** — Ingest a jewellery description into the RAG knowledge base.\n\nPipeline: description → OpenAI embedding → ChromaDB upsert","operationId":"rag_save_rag_save_post","requestBody":{"content":{"application/x-www-form-urlencoded":{"schema":{"$ref":"#/components/schemas/Body_rag_save_rag_save_post"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/rag/search":{"get":{"tags":["RAG Pipeline"],"summary":"Search for matching RAG transcripts","operationId":"rag_search_get_rag_search_get","parameters":[{"name":"query","in":"query","required":true,"schema":{"type":"string","description":"Natural-language search query","title":"Query"},"description":"Natural-language search query"},{"name":"top_k","in":"query","required":false,"schema":{"type":"integer","maximum":50,"minimum":1,"description":"Number of results","default":8,"title":"Top K"},"description":"Number of results"}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/rag/count":{"get":{"tags":["RAG Pipeline"],"summary":"Count stored RAG transcripts","operationId":"rag_count_rag_count_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/search":{"post":{"summary":"Search Image","description":"Upload a jewellery photo.\nPipeline:\n  1. image → GPT-4o Vision → natural language description\n  2. description → CLIP text encoder → FAISS search (against text-embedded catalog)\nThis gives semantic description-based matching instead of pixel-level similarity.","operationId":"search_image_search_post","parameters":[{"name":"top_k","in":"query","required":false,"schema":{"type":"integer","maximum":20,"minimum":1,"default":8,"title":"Top K"}}],"requestBody":{"required":true,"content":{"multipart/form-data":{"schema":{"$ref":"#/components/schemas/Body_search_image_search_post"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/search/describe":{"post":{"summary":"Describe Image Only","description":"Upload an image → GPT-4o Vision → return description text only.\nThe frontend then uses this description as a RAG query.","operationId":"describe_image_only_search_describe_post","requestBody":{"content":{"multipart/form-data":{"schema":{"$ref":"#/components/schemas/Body_describe_image_only_search_describe_post"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/image/proxy":{"get":{"summary":"Image Proxy","description":"Server-side image proxy.\nFetches an image from an external URL (e.g. sjadau.jewelscore.com which\nblocks direct browser requests via hotlink protection) and streams it back\nto the browser with the correct Referer header set server-side.\n\nUsage: /image/proxy?url=https://sjadau.jewelscore.com/f/skuimage/BGSNL-1018_1.jpg","operationId":"image_proxy_image_proxy_get","parameters":[{"name":"url","in":"query","required":true,"schema":{"type":"string","title":"Url"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/catalog/options":{"get":{"summary":"Catalog Options","description":"Return distinct values for filter dropdowns (from MongoDB catalog + product_details).","operationId":"catalog_options_catalog_options_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/catalog/parse":{"post":{"summary":"Catalog Parse","description":"Parse a natural-language query into catalog filter fields using OpenAI GPT.\nFalls back to regex matching if OpenAI fails.\nReturns: { item_name, style_name, metal_code, color_name, sku_name, min_price, max_price, in_stock }","operationId":"catalog_parse_catalog_parse_post","requestBody":{"content":{"application/x-www-form-urlencoded":{"schema":{"$ref":"#/components/schemas/Body_catalog_parse_catalog_parse_post"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/catalog/describe-from-url":{"post":{"summary":"Describe From Url","description":"Given an image URL and a SKU name:\n  1. Download the image from the URL\n  2. Send it to GPT-4o Vision to generate a jewellery description\n  3. Save the description to catalog, product_details, product_list for the matching SKU(s)\n  4. Return the generated description + matched SKUs","operationId":"describe_from_url_catalog_describe_from_url_post","requestBody":{"content":{"application/x-www-form-urlencoded":{"schema":{"$ref":"#/components/schemas/Body_describe_from_url_catalog_describe_from_url_post"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/catalog/update-description":{"post":{"summary":"Update Description","description":"Search for products whose sku_name contains the given search term (LIKE %sku_name%),\nthen update the description column in catalog, product_details, and product_list\nfor every matching SKU.\n\nReturns the list of matched SKUs and how many rows were updated.","operationId":"update_description_catalog_update_description_post","requestBody":{"content":{"application/x-www-form-urlencoded":{"schema":{"$ref":"#/components/schemas/Body_update_description_catalog_update_description_post"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/catalog/filter":{"get":{"summary":"Catalog Filter","description":"Filter catalog items joined with product_details and product_list.\nSupports stone_name filtering via stone_list_json.","operationId":"catalog_filter_catalog_filter_get","parameters":[{"name":"item_name","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Item Name"}},{"name":"style_name","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Style Name"}},{"name":"metal_code","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Metal Code"}},{"name":"color_name","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Color Name"}},{"name":"sku_name","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Sku Name"}},{"name":"stone_name","in":"query","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Stone Name"}},{"name":"stone_shape","in":"query","required":false,"schema":{"anyOf":[{"type":