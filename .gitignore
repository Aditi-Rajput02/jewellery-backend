# ─────────────────────────────────────────────────────────────────────────────
# backend/.gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment / Secrets (NEVER commit) ─────────────────────────────────────
.env
.env.local
.env.*.local
# .env.example is safe to commit

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
env/
.venv/

# ── ChromaDB vector store (auto-generated at runtime) ────────────────────────
rag_chroma_db/
chroma_db/

# ── FAISS index + metadata (auto-generated by build_index.py) ────────────────
index.faiss
metadata.json

# ── Raw API data dumps (large, regenerated by scripts) ───────────────────────
data_catalog.json
data_product_list.json
data_product_details.json

# ── Static uploads / temp files ───────────────────────────────────────────────
static/uploads/
*.tmp
*.bak

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Large model weights (downloaded by CLIP / HuggingFace) ───────────────────
*.bin
*.safetensors
*.pt
*.pth
